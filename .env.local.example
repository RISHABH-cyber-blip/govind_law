# ============================================================
# .env.local — Environment Variables
# COPY this file to .env.local and fill in your actual values.
# NEVER commit .env.local to git — it contains sensitive credentials.
# ============================================================

# Gmail SMTP credentials for Nodemailer contact form
# Use a Gmail App Password (NOT your regular Gmail password)
# To create App Password: Google Account → Security → 2-Step Verification → App passwords
EMAIL_USER=youremail@gmail.com
EMAIL_PASS=your_16_character_app_password

# Where contact form submissions get sent (usually same as EMAIL_USER)
RECIPIENT_EMAIL=youremail@gmail.com
